# ===========================================
# Propyte Web — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to the repository
# ===========================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Mapbox (interactive map) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_PHONE=529841234567

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=https://propyte.com

# --- Analytics (optional) ---
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_HOTJAR_ID=1234567

# --- Webhook (optional) ---
NEXT_PUBLIC_WEBHOOK_URL=https://your-webhook-endpoint.com
